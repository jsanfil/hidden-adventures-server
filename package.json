{
  "name": "hidden-adventures-server",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript backend for the Hidden Adventures rebuild",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "npm run dev:automation",
    "dev:manual-qa": "node --watch --env-file=.env.local.manual-qa --import tsx ./src/index.ts",
    "dev:automation": "node --watch --env-file=.env.local.automation --import tsx ./src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/scripts/run-migrations.ts",
    "db:migrate:dist": "node dist/scripts/run-migrations.js",
    "db:create:qa": "node --env-file=.env.local.manual-qa --import tsx ./src/scripts/db-create-local-database.ts",
    "db:create:test": "node --env-file=.env.local.automation --import tsx ./src/scripts/db-create-local-database.ts",
    "db:reset:qa": "node --env-file=.env.local.manual-qa --import tsx ./src/scripts/db-reset-local-database.ts",
    "db:reset:test": "node --env-file=.env.local.automation --import tsx ./src/scripts/db-reset-local-database.ts",
    "db:migrate:qa": "node --env-file=.env.local.manual-qa --import tsx ./src/scripts/run-migrations.ts",
    "db:migrate:test": "node --env-file=.env.local.automation --import tsx ./src/scripts/run-migrations.ts",
    "db:backup:local": "tsx src/scripts/backup-local-postgres.ts",
    "db:seed:local-fixtures": "POSTGRES_HOST=127.0.0.1 tsx src/scripts/seed-local-fixtures.ts",
    "fixtures:validate": "tsx src/scripts/fixtures-validate.ts",
    "fixtures:validate:qa": "node --env-file=.env.local.manual-qa --import tsx ./src/scripts/fixtures-validate.ts",
    "fixtures:validate:test": "node --env-file=.env.local.automation --import tsx ./src/scripts/fixtures-validate.ts",
    "fixtures:seed-db": "tsx src/scripts/fixtures-seed-db.ts",
    "fixtures:seed-db:qa": "node --env-file=.env.local.manual-qa --import tsx ./src/scripts/fixtures-seed-db.ts",
    "fixtures:seed-db:test": "node --env-file=.env.local.automation --import tsx ./src/scripts/fixtures-seed-db.ts",
    "fixtures:verify-media": "tsx src/scripts/fixtures-verify-media.ts",
    "fixtures:verify-media:qa": "node --env-file=.env.local.manual-qa --import tsx ./src/scripts/fixtures-verify-media.ts",
    "fixtures:provision-cognito": "tsx src/scripts/fixtures-provision-cognito.ts",
    "fixtures:provision-cognito:qa": "node --env-file=.env.local.manual-qa --import tsx ./src/scripts/fixtures-provision-cognito.ts",
    "fixtures:mint-test-token": "tsx src/scripts/auth/fixtures-mint-test-token.ts",
    "test:regression": "npm run db:migrate:test && npm run fixtures:validate:test -- --pack test-core && npm run fixtures:seed-db:test -- --pack test-core && npm test",
    "test:regression:clean": "npm run db:reset:test && npm run db:migrate:test && npm run fixtures:validate:test -- --pack test-core && npm run fixtures:seed-db:test -- --pack test-core && npm test",
    "auth:sync-cognito": "tsx src/scripts/sync-cognito-users.ts",
    "migration:stage-archive": "tsx src/scripts/stage-mongo-archive.ts",
    "migration:transform-stage": "tsx src/scripts/transform-stage-to-work.ts",
    "migration:publish-run": "tsx src/scripts/publish-run.ts",
    "migration:link-cognito": "tsx src/scripts/link-cognito-users.ts",
    "smoke:staging": "sh deploy/smoke/staging-smoke.sh"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1019.0",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
